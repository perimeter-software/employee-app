# Next.js Auth0 Configuration for v3
AUTH0_SECRET=your_auth0_secret_here
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-auth0-domain.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_AUDIENCE=https://your-auth0-domain.us.auth0.com/api/v2/

# V4 (Clerk) toggle. When true, the app uses Clerk for auth instead of Auth0.
# Both server and client must agree, so set the NEXT_PUBLIC_ copy at build time.
NEXT_PUBLIC_IS_V4=false
# Clerk keys (required when NEXT_PUBLIC_IS_V4=true)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_ENV='development'

# Local: yarn preview:cluster (build + cluster)
# CLUSTER_ENABLED=true
# CLUSTER_WORKERS=2
# 0 = auto (CPU count). Omit CLUSTER_ENABLED or set false for single-process next start.

# Database Configuration
# MongoDB Connection String (Dev/Staging/Production)
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

SP1_REDIS_HOST=127.0.0.1
SP1_REDIS_PORT=6379
SP1_REDIS_URL=redis://127.0.0.1:6379

# Google Maps API Keys
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_API_KEY_TWO=your_secondary_google_maps_api_key

# AI API Keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# AWS SES (required for sending invoice emails and OTP)
# Use IAM keys with ses:SendEmail + ses:SendRawEmail
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional: AWS_REGION (defaults to us-east-2)
# SES_FROM_EMAIL=jobs@stadiumpeople.com
# SES_SEND_IN_DEV=true

# Legacy Auth0 Variables (kept for backward compatibility with existing functions)
SECRET_AUTH0_CLIENT_ID=your_auth0_client_id
SECRET_AUTH0_CLIENT_SECRET=your_auth0_client_secret
SECRET_AUTH0_DOMAIN=your-auth0-domain.auth0.com
SECRET_AUTH0_AUDIENCE=http://localhost:3000
SECRET_AUTH0_SERVER_SECRET=your_auth0_secret_here

SES_SEND_IN_DEV=false
EMAIL_DIRECT_SEND=false

# Backend-to-backend (b2b) authentication with sp1-api
# BACKEND_JWT_SECRET_KEY must match the value set in sp1-api exactly
BACKEND_JWT_SECRET_KEY=your_backend_jwt_secret_key
SP1_API_BASE_URL=https://your-sp1-api-domain.com
SP1_API_ORIGIN=https://your-tenant-origin.com

NEXT_PUBLIC_IMAGE_SERVER=https://your-image-server-domain.com

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=